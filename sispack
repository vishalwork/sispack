#!/usr/bin/env bash

version='1.2'

strd_dir=$HOME
crtd_tmp='.sis_cache'
arrng='-h'
srtfl="$strd_dir/$crtd_tmp.txt"
hrln='--------------------------------------------'

# OS Detection
detect_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif command -v dpkg-query &>/dev/null; then
        echo "debian"
    elif command -v rpm &>/dev/null; then
        echo "rpm"
    elif command -v pacman &>/dev/null; then
        echo "arch"
    else
        echo "unknown"
    fi
}

OS=$(detect_os)

# Package list per OS
get_packages() {
    case $OS in
        debian)
            dpkg-query --show --showformat='${Installed-Size} ${Package} ${Source}\n'
            ;;
        rpm)
            rpm -qa --queryformat '%{SIZE} %{NAME} %{GROUP}\n' | awk '{printf "%d %s %s\n", $1/1024, $2, $3}'
            ;;
        arch)
            pacman -Qi | awk '
                /^Name/ { name=$3 }
                /^Installed Size/ {
                    size=$4; unit=$5
                    if (unit == "MiB") size=size*1024
                    if (unit == "GiB") size=size*1024*1024
                    printf "%d %s\n", size, name
                }'
            ;;
        macos)
            # 1. Homebrew packages
            if command -v brew &>/dev/null; then
                brew list --formula | while read pkg; do
                    size=$(du -sk "$(brew --prefix)/Cellar/$pkg" 2>/dev/null | awk '{print $1}')
                    echo "${size:-0} $pkg homebrew"
                done
            fi

            # 2. Applications folder (.app bundles)
            find /Applications -maxdepth 2 -name "*.app" 2>/dev/null | while read app; do
                size=$(du -sk "$app" 2>/dev/null | awk '{print $1}')
                name=$(basename "$app" .app)
                echo "${size:-0} $name applications"
            done

            # 3. pkgutil — Apple/system packages
            pkgutil --pkgs | while read pkg; do
                size=$(pkgutil --info "$pkg" 2>/dev/null | awk '/volume|install-location/ {print}' | head -1)
                # pkgutil reliable size nahi deta, sirf name show karo
                echo "0 $pkg system-pkg"
            done
            ;;
        *)
            echo "sispack: Unsupported OS!" >&2
            exit 1
            ;;
    esac
}

#  Execute
execute() {
    srtfl="$strd_dir/$crtd_tmp"
    
    # Pehle cache file banao
    get_packages | sort $arrng | awk '{printf "\t%.2f\n", $1/1024}' > "$srtfl"
    
    # Display alag karo
    get_packages | sort $arrng | awk \
        '{printf " \033[1;33;40m %.2f \033[35m Mb\033[0;1m \033[36m%s\033[0m\t%s\n", $1/1024, $2, $3}'
    
    sum_total
}      

sum_total() {
    awk -v ln="$hrln" \
        '{sum += $1}
         END {print " \033[1m"ln"\n \033[7mTotal:\033[0m\033[1m "sum" MB ===> "sum/1024" GB\n "ln" \033[0m"}' \
        "$srtfl"
}

find_name() {
    execute | grep "$1" > "$srtfl"
    n=2
    cat "$srtfl" && sum_total
    rm "$srtfl"
}

author() {
    echo -e "Created by:: Vishal_Kumar\nGithub Page: @vishalwork
\n\tOriginally forked from: @vlc-ranchi

\n[more...]\n\tType: Open Source\n\tWhy_created: Size-In-System Package\n\tBuilt to help users easily track and analyze installed package sizes on their system.\n\tBasedOn: BaShell
\tDate: 21/10/2021\n\tUpdated On:06/04/2026\n\tCountry: INDIA\n\tPlace: RANCHI-INDIA

\nVishal Kumar: \"Open source project built using Bash, awk & standard Unix tools.\""
}

# Argument Parsing
if test $# -ge 1; then
    while getopts :farhvV opt; do
        case $opt in
            f)
                if test $# -eq 2; then find_name "$2"
                else echo -e "Error: Enter name to search after [-f]"
                fi
                exit 1 ;;
            r) arrng='-hr' && execute; exit 1 ;;
            a) author; exit 1 ;;
            h)
                echo "Sispack version: $version
$hrln
[ Options ]
  -f : find/search specific subject.
  -h : Help window | This page.
  -r : Reverse the output.
  -a : See Author detail and more.
  -v|-V : Print version.

Supported: Debian/Ubuntu | RPM (Fedora/RHEL) | Arch Linux | macOS (Homebrew)
Example: [ sispack -f name_to_search ]
$hrln"
                exit 1 ;;
            v|V) echo "$version" ;;
            \?) echo "sispack: Invalid input: $1"; exit 1 ;;
        esac
    done
else
    execute
fi
